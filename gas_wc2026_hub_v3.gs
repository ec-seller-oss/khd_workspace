function sh_block(sh, row, header, pairs) {
  sec(sh, row, header);
  const data = pairs.map(p => [p[0], p[1]]);
  sh.getRange(row + 1, 1, data.length, 2).setValues(data).setWrap(true).setVerticalAlignment('middle');
  sh.setColumnWidth(1, 16); // 後で02bで上書きされるが基準
}


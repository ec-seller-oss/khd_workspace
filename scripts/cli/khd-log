#!/usr/bin/env python3
"""KHD作業ログ即時記録CLI（Notion作業ログDBへ追記）。

使い方:
  khd-log "タスク名" "カテゴリ" "作業内容" [関連URL]

カテゴリは以下から選択（未一致は"その他"扱い）:
  会社情報整理 / Notion設定 / MCP設定 / 開発作業 / その他

例:
  khd-log "船橋WBS更新" "開発作業" "解体見積3社確認、サンエー優位" "https://..."
"""
import json
import os
import sys
import urllib.request
from datetime import date as date_cls

WORK_LOG_DB = "3677d27fe29580df8323eb510dcdfea7"
NOTION_VERSION = "2022-06-28"
ALLOWED_CATS = {"会社情報整理", "Notion設定", "MCP設定", "開発作業", "その他"}


def main():
    if len(sys.argv) < 4:
        print("usage: khd-log <タスク名> <カテゴリ> <作業内容> [関連URL]", file=sys.stderr)
        sys.exit(1)
    title, category, content = sys.argv[1], sys.argv[2], sys.argv[3]
    url = sys.argv[4] if len(sys.argv) > 4 else None
    if category not in ALLOWED_CATS:
        category = "その他"

    with open(os.path.expanduser("~/.claude.json")) as f:
        cfg = json.load(f)
    token = cfg.get("mcpServers", {}).get("notion", {}).get("env", {}).get("NOTION_TOKEN")
    if not token:
        print("ERROR: NOTION_TOKEN not found in ~/.claude.json", file=sys.stderr)
        sys.exit(1)

    today = date_cls.today().isoformat()
    props = {
        "タスク名": {"title": [{"text": {"content": title}}]},
        "ステータス": {"status": {"name": "完了"}},
        "日付": {"date": {"start": today}},
        "カテゴリ": {"select": {"name": category}},
        "作業内容": {"rich_text": [{"text": {"content": content}}]},
    }
    if url:
        props["関連ページ"] = {"url": url}

    payload = {"parent": {"database_id": WORK_LOG_DB}, "properties": props}
    headers = {
        "Authorization": f"Bearer {token}",
        "Notion-Version": NOTION_VERSION,
        "Content-Type": "application/json",
    }
    req = urllib.request.Request(
        "https://api.notion.com/v1/pages",
        data=json.dumps(payload).encode(),
        headers=headers, method="POST",
    )
    with urllib.request.urlopen(req) as r:
        result = json.load(r)
    print(result.get("url", "(no url)"))


if __name__ == "__main__":
    main()

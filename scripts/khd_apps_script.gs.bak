// ── 修正案v3：本体コピーに全要件実装（報告ログ/03ハブ/05主格別ランウェイ/日報連動/収益パイプ削除）2026-06-06 ──
function buildSosa(body) {
  const ss = SpreadsheetApp.openById((body && body.hostId) || "1iG0Q7FgIIzX1CK9k7ypdqIwGGVY_-KwhwF75r5hqENk");
  const NIPPO = "129j7x0Y4icgzYdTs9s_w1GBnFMIdVMtrTXqHeapM_f8";
  const Y="#FFF2CC",B="#CFE2F3",G="#ECECEC",BR="#AA2E26",GR="#D9EAD3";
  function shk(kw){ var a=ss.getSheets(); for(var i=0;i<a.length;i++){ if(a[i].getName().indexOf(kw)>=0) return a[i]; } return null; }
  function tc(s,c){ if(s) s.setTabColor(c); }

  // 1) 不要タブ削除（収益パイプライン＝売上見込みと二重／v2途中版／未来会計図表）
  ["収益パイプライン","🔬経営診断","🎯事業計画","🪜KPI→WBS","未来会計図表"].forEach(function(nm){ var s=ss.getSheetByName(nm); if(s) ss.deleteSheet(s); });

  // 2) 📥報告ログ（追記専用＝消えない・ログ駆動）
  var lg=ss.getSheetByName("📥報告ログ"); if(lg) ss.deleteSheet(lg); lg=ss.insertSheet("📥報告ログ");
  lg.getRange(1,1,4,7).setValues([
    ["日付","種別","案件・相手","科目","項目","値","メモ"],
    ["2026-06-06","物件","栄町(持倉様)","物件売却","確度","0.9","6/8決済"],
    ["2026-06-06","医療","曾我先生","医療コンサル","確度","0.4","反応微妙→様子見"],
    ["★追記専用(絶対に消さない)。Claudeが報告から1行足す→03が最新参照→01/04/05が自動更新。過去が残るので連動が崩れない","","","","","",""]
  ]);
  lg.getRange("A1:G1").setBackground(BR).setFontColor("#FFFFFF").setFontWeight("bold");
  lg.getRange("A2:G3").setBackground(Y); lg.getRange("A4").setFontColor(BR).setFontWeight("bold");

  // 3) 03_売上見込み ハブ（連動列は不可侵・N列以降を追加）
  var u=shk("売上見込み");
  if(u){

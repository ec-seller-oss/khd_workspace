/**
 * KHD WBS 業務報告 Webhook v2
 * スプレッドシート → 拡張機能 → Apps Script に貼り付けて「デプロイ」
 *
 * デプロイ設定:
 *   種類: ウェブアプリ
 *   次のユーザーとして実行: 自分
 *   アクセスできるユーザー: 全員
 */

const SECRET_TOKEN = "khd_report_2026";
const NIPPO_ID = "129j7x0Y4icgzYdTs9s_w1GBnFMIdVMtrTXqHeapM_f8"; // KHD日報ログ（別ファイル）
const CASHFLOW_ID = "1ofLJOFuW5175OHDSy0J0561LzrfAU-M015o7ByGH5wc"; // 資金繰り司令塔（収益パイプライン同居先）

function doPost(e) {
  try {
    const body = JSON.parse(e.postData.contents);
    if (body.token !== SECRET_TOKEN) return json({ ok: false, error: "unauthorized" });

    const action = body.action;
    let result;

    if      (action === "update_wbs")      result = updateWbs(body.task, body.status, body.progress);
    else if (action === "update_study")    result = updateStudy(body);
    else if (action === "update_kpi")      result = updateKpi(body);
    else if (action === "append_log")      result = appendLog(body);
    else if (action === "ping")            result = { pong: true };
    else if (action === "debug_sheet")     result = debugSheet(body.partial);
    else if (action === "parse_and_update")   result = parseAndUpdate(body.text);
    else if (action === "get_wbs_summary")    result = getWbsSummary();
    else if (action === "check_calendar")     result = checkEndingEvents();
    else if (action === "log_conversation")   result = logConversation(body);
    else if (action === "get_next_task")      result = getNextTask();
    else if (action === "write_nippo")        result = writeNippo(body);
    else if (action === "append_nippo")       result = appendNippo(body);
    else if (action === "write_pipeline")     result = writePipeline(body);
    else if (action === "format_rules")        result = formatOperatingRules();
    else if (action === "finance_fixes")       result = applyFinanceFixes();
    else if (action === "tidy_tabs")           result = tidyTabs();
    else if (action === "build_blueprint")     result = buildBlueprint(body);
    else if (action === "build_v2_layers")     result = buildV2Layers(body);
    else if (action === "build_kairyou")       result = buildKairyou(body);
    else if (action === "build_ops")           result = buildOps(body);
    else if (action === "build_sosa")          result = buildSosa(body);
    else if (action === "build_db02")          result = buildDB02(body);
    else if (action === "build_wire0203")      result = buildWire0203(body);
    else if (action === "fix_wire0203")        result = fixWire0203(body);
    else result = { error: "unknown action: " + action };

    return json({ ok: true, result });
  } catch (err) {
    return json({ ok: false, error: err.toString() });
  }
}

// ── WBS タスク更新 ────────────────────────────────────
function updateWbs(taskPartial, newStatus, newProgress) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName("02_全社WBS");
  if (!sheet) return { error: "WBSシートが見つかりません" };

  const data = sheet.getDataRange().getValues();

  // ヘッダー行をスキャンして探す
  let headerRow = -1, colStatus = -1, colProgress = -1;
  for (let i = 0; i < data.length; i++) {
    const idx = data[i].indexOf("ステータス");
    if (idx >= 0) {
      headerRow = i;
      colStatus   = idx;
      colProgress = data[i].indexOf("進捗率");
      break;
    }
  }
  if (headerRow < 0) return { error: "WBSヘッダーが見つかりません" };

  // 工程列（タスク名）を特定
  const colTask = data[headerRow].indexOf("工程");

  for (let i = headerRow + 1; i < data.length; i++) {
    const taskName = String(colTask >= 0 ? data[i][colTask] : data[i][1]).trim();
    if (taskName && taskName.includes(taskPartial)) {
      const updated = [];
      if (notNull(newStatus)   && colStatus   >= 0) { sheet.getRange(i+1, colStatus+1).setValue(newStatus);   updated.push("ステータス→" + newStatus); }
      if (notNull(newProgress) && colProgress >= 0) { sheet.getRange(i+1, colProgress+1).setValue(newProgress); updated.push("進捗率→" + newProgress); }
      return { task: taskName, row: i+1, updated };
    }
  }
  return { error: "タスクが見つかりません: " + taskPartial };
}

// ── 調査士学習ログ更新 ────────────────────────────────
function updateStudy(body) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = findSheetByPartial(ss, "05");
  if (!sheet) return { error: "学習ログシートが見つかりません" };

  const today = todayStr();
  const data  = sheet.getDataRange().getValues();

  // ヘッダー行スキャン
  let headerRow = -1, header = [];
  for (let i = 0; i < data.length; i++) {
    if (data[i].includes("実績時間")) { headerRow = i; header = data[i]; break; }
  }
  if (headerRow < 0) return { error: "学習ログヘッダーが見つかりません", headers_row0: data[0] };

  for (let i = headerRow + 1; i < data.length; i++) {
    if (dateMatches(data[i][0], today)) {
      const row = i + 1;
      const updated = [];
      const colMap = [
        ["実績時間",   body.hours],
        ["範囲(択一)", body.range_takuitsu],
        ["範囲(記述)", body.range_kijutsu],
        ["ミス問数",   body.miss_count],
        ["コメント",   body.comment],
        ["完遂",       body.kansei],
      ];
      colMap.forEach(([col, val]) => {
        if (!notNull(val)) return;
        const ci = header.indexOf(col);
        if (ci >= 0) { sheet.getRange(row, ci+1).setValue(val); updated.push(col + "→" + val); }
      });
      return { sheet: sheet.getName(), row, updated };
    }
  }
  return { error: "今日の行が見つかりません (" + today + ")" };
}

// ── KPI 5指標更新 ─────────────────────────────────────
function updateKpi(body) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = findSheetByPartial(ss, "06");
  if (!sheet) return { error: "KPIシートが見つかりません" };

  const today = todayStr();
  const data  = sheet.getDataRange().getValues();

  // ヘッダー行スキャン
  let headerRow = -1, header = [];
  for (let i = 0; i < data.length; i++) {
    if (data[i].some(h => String(h).includes("他力") || String(h).includes("朝活"))) {
      headerRow = i; header = data[i]; break;
    }
  }
  if (headerRow < 0) return { error: "KPIヘッダーが見つかりません" };

  for (let i = headerRow + 1; i < data.length; i++) {
    if (dateMatches(data[i][0], today)) {
      const row = i + 1;
      const updated = [];

      // 各列を名前で検索して書き込む
      const kpiMap = [
        ["他力",   body.tariki],
        ["EQ",     body.eq],
        ["朝活",   body.chokatsu],
        ["戦サボ", body.sen_sabo],
        ["家族",   body.kazoku],
        ["コメント", body.comment],
        ["TOP3",   body.top3],
      ];
      kpiMap.forEach(([keyword, val]) => {
        if (!notNull(val)) return;
        const ci = header.findIndex(h => String(h).includes(keyword));
        if (ci >= 0) { sheet.getRange(row, ci+1).setValue(val); updated.push(header[ci] + "→" + val); }
      });

      return { sheet: sheet.getName(), row, updated };
    }
  }
  return { error: "今日のKPI行が見つかりません (" + today + ")" };
}

// ── 日次ログ追記 ──────────────────────────────────────
function appendLog(body) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = findSheetByPartial(ss, "14");
  if (!sheet) return { error: "日次ログシートが見つかりません" };

  const lastRow = sheet.getLastRow() + 1;
  const now = todayStr() + " " + (body.time || formatTime(new Date()));
  const values = [now, body.category||"", body.dept||"", body.content||"",
                  body.project||"", body.manager_comment||"", body.wbs_reflect||"",
                  body.status||"🟡 確認待ち"];
  sheet.getRange(lastRow, 1, 1, values.length).setValues([values]);
  return { sheet: sheet.getName(), row: lastRow, written: body.content };
}

// ── 日報ログ：全置換ミラー（ローカルCSVを丸ごと反映・URL固定） ──
function writeNippo(body) {
  const rows = body.rows; // ヘッダ込み2D配列
  if (!rows || !rows.length) return { error: "rowsが空です" };
  const ss = SpreadsheetApp.openById(NIPPO_ID);
  const sheet = ss.getSheets()[0];
  sheet.clearContents();
  sheet.getRange(1, 1, rows.length, rows[0].length).setValues(rows);
  return { written: rows.length, sheet: sheet.getName() };
}

// ── 日報ログ：末尾に行追記（積み上げ・予定/実績の差分用） ──
function appendNippo(body) {
  const rows = body.rows; // データ行のみ（ヘッダ除く）2D配列
  if (!rows || !rows.length) return { error: "rowsが空です" };
  const ss = SpreadsheetApp.openById(NIPPO_ID);
  const sheet = ss.getSheets()[0];
  sheet.getRange(sheet.getLastRow()+1, 1, rows.length, rows[0].length).setValues(rows);
  return { appended: rows.length, lastRow: sheet.getLastRow() };
}

// ── タブをキーワード（名前の一部）で探す＝番号プレフィックス改名後も壊れない ──
function shByKey(ss, kw) {
  var a = ss.getSheets();
  for (var i = 0; i < a.length; i++) { if (a[i].getName().indexOf(kw) >= 0) return a[i]; }
  return null;
}

// ── 収益パイプライン：資金繰りスプシ内の「収益パイプライン」タブへ全置換ミラー ──
// 同居タブ化（残務B）。rows = ヘッダ込み2D配列。"="始まりのセルは数式として展開される。
function writePipeline(body) {
  const rows = body.rows;
  if (!rows || !rows.length) return { error: "rowsが空です" };
  const ss = SpreadsheetApp.openById(body.hostId || CASHFLOW_ID);
  let sheet = shByKey(ss, "収益パイプライン");
  if (!sheet) sheet = ss.insertSheet("10_収益パイプライン");
  sheet.clearContents();
  sheet.getRange(1, 1, rows.length, rows[0].length).setValues(rows);
  return { written: rows.length, sheet: sheet.getName(), host: ss.getName() };
}

// ── 運用ルールの色分け（マニュアル不要化）────────────────────
// 色＝ルール。🟡入力 / 🟧毎日見る / 🟦週次月次で見る / ⬜自動・触らない。背景色のみで値は壊さない。
function formatOperatingRules() {
  const C = { IN:"#FFF2CC", DAY:"#FCE5CD", WATCH:"#CFE2F3", AUTO:"#ECECEC", HEAD:"#434343" };
  const ss = SpreadsheetApp.openById(CASHFLOW_ID);
  const out = [];
  function f(sh, a1, color, note) {
    const rg = sh.getRange(a1);
    if (color) rg.setBackground(color);
    if (note != null) rg.setNote(note);
  }
  function legend(sh, startRow) {
    const r = startRow;
    sh.getRange(r,1).setValue("📖 このタブの使い方（色＝運用ルール）").setFontWeight("bold").setFontColor("#FFFFFF").setBackground(C.HEAD);
    const rows = [
      ["🟡 黄＝【入力】あなたが打つ（頻度はセルのメモを参照）", C.IN],
      ["🟧 橙＝【毎日見る】今日の一手・追客目標", C.DAY],
      ["🟦 青＝【週次/月次で見る】判断に使うKPI", C.WATCH],
      ["⬜ 灰＝自動計算・触らない", C.AUTO],
    ];
    for (let i=0;i<rows.length;i++){
      sh.getRange(r+1+i,1).setBackground(rows[i][1]);
      sh.getRange(r+1+i,2).setValue(rows[i][0]);
    }
  }

  // ① 売上見込み（金額のSSoT）
  let s = shByKey(ss, "売上見込み");
  if (s) {
    f(s,"B2",C.IN,"【入力・月初/会議前】シナリオを 弱気/現実/強気 で打ち替え");
    f(s,"A5:G14",C.IN,"【入力・案件が動くたび】本部/科目/案件名/満額(E)/確度(F)/着金月(G)。科目は栄町売却・医療テナントコンサル・テレアポ買取再販のみ。着金月は2026/06形式");
    f(s,"H5:K14",C.AUTO,"自動・触らない（シナリオ別採用額）");
    f(s,"M5:M14",C.AUTO,"自動・触らない（期待値=満額×確度）");
    f(s,"B17:B19",C.AUTO,"自動・触らない（案件別採用額）");
    f(s,"B20",C.WATCH,"【見る・週次】採用額合計＝今のシナリオで④資金繰りに流れる額");
    f(s,"B21",C.WATCH,"【見る・週次/月次】期待値合計＝確度加重の収入見込み（収益パイプラインの真実源）");
    legend(s, 28);
  }
  // ⑦ 損益（PL）：営業ドライバー＝逆算エンジン
  s = shByKey(ss, "損益");
  if (s) {
    f(s,"B48",C.IN,"【入力・ほぼ固定】営業直結 目標時間比率（既定0.6）");
    f(s,"B52",C.IN,"【入力・月1回】追客→アポ 転換率（自分の実績で更新）");
    f(s,"B53",C.IN,"【入力・月1回】アポ→成約 転換率（自分の実績で更新）");
    f(s,"B57",C.IN,"【入力・月初】月の稼働日");
    f(s,"B49",C.DAY,"【毎日見る】今日の一手");
    f(s,"B59",C.DAY,"【毎日見る】今日の追客目標");
    f(s,"B63",C.DAY,"【毎日見る】時間の一手");
    f(s,"B34",C.WATCH,"【見る・週次/月次】経常ギャップ＝毎月埋める穴");
    f(s,"B42:B43",C.WATCH,"【見る・月次】家族/黒字ラインに必要な医療件数");
    f(s,"B45",C.WATCH,"【見る・月次】家族ラインに必要な物件件数");
    f(s,"B58",C.WATCH,"【見る・週次】1日あたり必要追客数");
    f(s,"B67:F70",C.WATCH,"【見る・月次】月次トラッキング（必要vs確定vs不足）");
    f(s,"B32",C.AUTO,"自動（経常確定粗利）"); f(s,"B33",C.AUTO,"自動（家族ライン）"); f(s,"B41",C.AUTO,"自動（医療確度込/件）");
    legend(s, 72);
  }
  // ④ 資金繰り（結果・原則見るだけ。固定費だけ入力）
  s = shByKey(ss, "資金繰り");
  if (s) {
    f(s,"B5:I8",C.AUTO,"自動・触らない（売上見込み/IMPORTRANGE連動の入金）");
    f(s,"B10",C.IN,"【入力・変わったら】育休給付");
    f(s,"B14:I26",C.IN,"【入力・変わったら】固定費・出金（半固定）");
    f(s,"B12:I12",C.AUTO,"自動（入金合計）"); f(s,"B27:I27",C.AUTO,"自動（出金合計）");
    f(s,"B29:I29",C.WATCH,"【見る・週次/月次】月末現預金＝体力計");
    f(s,"B32",C.WATCH,"【見る・週次】ランウェイ判定");
    legend(s, 36);
  }
  // 収益パイプライン（営業の的リスト・CSV経由で更新）
  s = shByKey(ss, "収益パイプライン");
  if (s) {
    f(s,"K2:L8",C.IN,"【更新・随時／CSV経由】次アクション・ステータス（私に『パイプライン反映して』で書込）");
    f(s,"I2:I8",C.AUTO,"自動（各ゴールの確度加重・作業用）");
    f(s,"C12:I13",C.WATCH,"【見る・週次】売上見込み(SSoT)連動の確定値");
    f(s,"C14:I14",C.WATCH,"【見る・週次】取りこぼしチェック＝＞0なら売上見込み未登録案件あり");
    legend(s, 16);
  }
  out.push("formatted");
  return { ok:true, tabs:["売上見込み","⑦ 損益（PL）","④ 資金繰り","収益パイプライン"] };
}

// ── 財務修正バンドル（税理士/経常利益色/色ズレ/未来会計図表参照化）2026-06-05 ──
function applyFinanceFixes() {
  const ss = SpreadsheetApp.openById(CASHFLOW_ID);
  const cf = shByKey(ss, "資金繰り");
  const pl = shByKey(ss, "損益");
  const mf = shByKey(ss, "未来会計図表");
  const Y="#FFF2CC", O="#FCE5CD", B="#CFE2F3", GOLD="#FFE599";

  // 1) 税理士を契約ベースの正値へ（B:I＝6月〜1月の8列）
  cf.getRange("B14:I14").setValue(18333);  // 法人税理士 決算22万/年÷12
  cf.getRange("B17:I17").setValue(46750);  // 個人税理士 税込56.1万/年÷12

  // 2) PL固定費計B7＝18333+99000+22167+50000=189500／個人税理士B16=46750／ラベル更新
  pl.getRange("B7:I7").setValue(189500);
  pl.getRange("B16:I16").setValue(46750);
  pl.getRange("A7").setValue("  固定費計（税理士18,333+外注99,000+社保22,167＋役員報酬50,000※未払＝189,500）");

  // 3) 経常利益を結論色(金)＋太字に・支払利息の緑を外して区別
  pl.getRange("B8:I8").setBackground(null);
  [9,17,25].forEach(function(r){ var rg=pl.getRange(r,2,1,8); rg.setBackground(GOLD); rg.setFontWeight("bold"); });

  // 4) 営業ドライバーの色ズレ修正：誤りクリア→正しい行へ
  ["B33","B48","B49","B53","B57","B59","B63","B67"].forEach(function(a){ pl.getRange(a).setBackground(null); });
  ["B51","B55","B56","B60"].forEach(function(a){ pl.getRange(a).setBackground(Y); });  // 入力
  ["B52","B62","B66"].forEach(function(a){ pl.getRange(a).setBackground(O); });          // 毎日見る
  ["B37","B45","B46","B48","B58","B61"].forEach(function(a){ pl.getRange(a).setBackground(B); }); // 週次見る

  // 5) 未来会計図表を⑦PL参照化（固定費・目標利益→損益分岐の二重/矛盾を解消）
  mf.getRange("B4").setFormula("='⑦ 損益（PL）'!B24");
  mf.getRange("B5").setFormula("='⑦ 損益（PL）'!B26");
  mf.getRange("A2").setValue("※固定費・目標利益・損益分岐は⑦損益PLを参照（PL一本化／このタブは図示用）");

  return { ok:true, taxFixed:true, keijo:"gold", driverRecolored:true, miraiLinked:true };
}

// ── タブ整理：日常で使う順に並べ替え＋データ/スポットは非表示（名前は変えない＝参照壊れない）──
function tidyTabs() {
  const ss = SpreadsheetApp.openById(CASHFLOW_ID);
  // 表示する操縦席（この順＝流れ）。[探すキーワード, 新しい名前(01_〜)]
  const front = [
    ["統合司令塔",   "01_統合司令塔"],
    ["追客リスト",   "02_追客リスト"],
    ["売上見込み",   "03_売上見込み"],
    ["損益",         "04_損益PL"],
    ["資金繰り",     "05_資金繰り"],
    ["資産負債",     "06_資産負債BS"],
    ["本部マトリクス","07_本部マトリクス"],
    ["残高クイック", "08_残高クイック入力"],
    ["MF残高",       "09_MF残高"],
    ["収益パイプライン","10_収益パイプライン"],
    ["KPI",          "11_KPI"]
  ];
  // 非表示にする（データ源・スポット・アーカイブ。計算は生きる・いつでも再表示可）
  const hide = [
    "⑤ 借入", "借入返済", "借入条件", "税金", "諸経費", "クレカ用途",
    "按分_260604", "役員報酬", "経費削減・損切り",
    "💼銀行提出前クリーンアップ", "事業計画（5ヵ年）", "未来会計図表",
    "WBS"
  ];
  // ※pass(ID/パスワード管理)はよく使うので表示のまま（菊池確定2026-06-05）
  // 不要2枚を削除（菊池確定2026-06-05・戻せない）：⑥使い方=マニュアルで代替／📋テンプレ=按分_260604の重複
  const del = ["⑥使い方", "📋按分棚卸し_テンプレ"];
  var deleted = [];
  del.forEach(function(nm){
    var sh = ss.getSheetByName(nm);
    if (sh){ ss.deleteSheet(sh); deleted.push(nm); }
  });
  // まず表示対象をキーワードで探し→01_に改名→show→流れ順に前へ（数式参照は自動追従）
  front.forEach(function(pair, i){
    var sh = shByKey(ss, pair[0]);
    if (sh){ sh.setName(pair[1]); sh.showSheet(); ss.setActiveSheet(sh); ss.moveActiveSheet(i+1); }
  });
  // 残りを非表示
  var hidden = [];
  hide.forEach(function(nm){
    var sh = ss.getSheetByName(nm);
    if (sh){ sh.hideSheet(); hidden.push(nm); }
  });
  // 先頭（①司令塔）をアクティブに戻す
  var top = shByKey(ss, "統合司令塔"); if (top) ss.setActiveSheet(top);
  return { ok:true, shown:front.length, hidden:hidden.length, deleted:deleted };
}

// ── ブループリント設計版スプシを構築（3層・報告→自動転記モデル）2026-06-06 ──
function buildBlueprint(body) {
  const ss = SpreadsheetApp.openById((body && body.hostId) || "1pXGpe3hXaxGEAPq_asP_pm3mruL-NNFIlG14wB_1Ego");
  const Y="#FFF2CC",O="#FCE5CD",B="#CFE2F3",GOLD="#FFE599",G="#ECECEC",BR="#AA2E26";
  function mk(name){ var s=ss.getSheetByName(name); if(s) ss.deleteSheet(s); return ss.insertSheet(name); }
  function put(s,arr){ s.getRange(1,1,arr.length,arr[0].length).setValues(arr); }
  function bg(s,a1,c){ s.getRange(a1).setBackground(c); }
  function head(s,a1){ s.getRange(a1).setBackground(BR).setFontColor("#FFFFFF").setFontWeight("bold"); }

  // 01_売上見込み（L1入力：法人売上の科目源）
  var s1=mk("01_売上見込み");
  put(s1,[
    ["科目","案件名","満額","確度","着金月","期待値(自動)","メモ"],
    ["医療コンサル","曾我先生(千葉都町)",1100000,0.4,"2026-07","=C2*D2","眼科・反応微妙"],
    ["医療コンサル","内山先生",1100000,0.15,"","=C3*D3","再探索"],
    ["物件売却","栄町(持倉様)",1900000,0.9,"2026-06","=C4*D4","6/8決済"],
    ["物件売却","高松転売",4000000,0.3,"2026-07","=C5*D5","査定中"],
    ["","","","","","=SUM(F2:F5)","◀期待値合計(確度加重)"],
  ]);
  head(s1,"A1:G1"); bg(s1,"C2:E5",Y); bg(s1,"F2:F6",G); s1.getRange("F6").setFontWeight("bold");

  // 02_営業ログ（L1入力＝あなたの「報告」をClaudeが転記する先）
  var s2=mk("02_営業ログ");
  put(s2,[
    ["日付","相手","科目","行動","結果","次アクション"],
    ["2026-06-05","曾我先生","医療コンサル","福井下書き作成","微妙な反応","様子見・関係維持"],
    ["2026-06-05","内山先生","医療コンサル","福井下書き作成","微妙な反応","様子見"],
    ["2026-06-06","大坪さん","物件売却","口座確認連絡","","6/8決済へ"],
    ["（報告するとClaudeがここに1行追加→確度が動けば01へ反映）","","","","",""],
  ]);
  head(s2,"A1:F1"); bg(s2,"A2:F5",O);

  // 03_PL（L2自動：科目別損益。手打ち=固定費/目標利益だけ）
  var s3=mk("03_PL");
  put(s3,[
    ["科目","金額","メモ"],
    ["■法人売上","",""],
    ["  医療コンサル(確度加重)","=SUMIF('01_売上見込み'!A:A,\"医療コンサル\",'01_売上見込み'!F:F)","01から自動"],
    ["  物件売却(確度加重)","=SUMIF('01_売上見込み'!A:A,\"物件売却\",'01_売上見込み'!F:F)","01から自動"],
    ["  EC粗利(月・実精算)",142731,"ECダッシュボードから(暫定手入力)"],
    ["限界利益(粗利計)","=B3+B4+B5","=売上−変動費"],
    ["固定費(税理士/外注/社保/役員報酬等)",189500,"入力(半固定)"],
    ["経常利益","=B6-B7","結論ライン"],
    ["目標利益(入力)",500000,"入力"],
    ["損益分岐(固定費+目標利益)","=B7+B9","これ超で黒字"],
    ["判定","=IF(B6>=B10,\"🟢 黒字達成\",\"🔴 未達 不足\"&TEXT(B10-B6,\"#,##0\")&\"円\")",""],
  ]);
  head(s3,"A1:C1"); bg(s3,"B7",Y); bg(s3,"B9",Y); bg(s3,"B8",GOLD); s3.getRange("B8").setFontWeight("bold"); bg(s3,"B3:B6",G); bg(s3,"B10:B11",B);

  // 04_資金繰り（L2自動：PLから現金）
  var s4=mk("04_資金繰り");
  put(s4,[
    ["項目","金額","メモ"],
    ["月初現金(入力)",8743221,"残高入力 or BS連動"],
    ["入金(=PL限界利益)","='03_PL'!B6","自動"],
    ["出金(=PL固定費)","='03_PL'!B7","自動"],
    ["当月純増減","=B3-B4","自動"],
    ["月末現金(体力計)","=B2+B5","自動"],
    ["月次燃焼(固定費−経常入金EC)","='03_PL'!B7-'03_PL'!B5","自動"],
    ["ランウェイ(月)","=B2/B7","自動"],
    ["判定","=IF(B8<3,\"🔴守り:投資凍結\",IF(B8<6,\"🟡注意\",\"🟢攻めOK\"))",""],
  ]);
  head(s4,"A1:C1"); bg(s4,"B2",Y); bg(s4,"B3:B5",G); bg(s4,"B6",B); bg(s4,"B8:B9",B);

  // 05_時間配分（L1入力：営業直結比率の源＝目標/予定/実績の3本）
  var s5=mk("05_時間配分");
  put(s5,[
    ["指標","値","計算の意味＝なぜ動くか"],
    ["目標 営業直結比率",0.6,"あるべき姿(固定)"],
    ["予定 営業時間/週(h)",6,"カレンダーで営業に振った予定"],
    ["総予定時間/週(h)",40,""],
    ["予定 営業直結比率","=B3/B4","朝の予定づくりで動く"],
    ["実績 営業時間/週(h)",2,"日報の実営業"],
    ["総実時間/週(h)",38,""],
    ["実績 営業直結比率","=B6/B7","夜の実績入力で動く"],
    ["計画と実行のギャップ","=B5-B8","予定−実績＝漏れ(これが本当のボトルネック信号)"],
  ]);
  head(s5,"A1:C1"); bg(s5,"B3:B4",Y); bg(s5,"B6:B7",Y); bg(s5,"B5",B); bg(s5,"B8:B9",B); bg(s5,"B2",G);

  // 00_司令塔（L3読むだけ）
  var s0=mk("00_司令塔");
  put(s0,[
    ["① 統合司令塔（操縦席）— 読むだけ",""],
    ["◆ 現在（体力）",""],
    ["現預金","='04_資金繰り'!B6"],
    ["ランウェイ(月)","='04_資金繰り'!B8"],
    ["体力判定","='04_資金繰り'!B9"],
    ["◆ 損益（詳細→03_PL）",""],
    ["限界利益(粗利)","='03_PL'!B6"],
    ["損益分岐","='03_PL'!B10"],
    ["黒字判定","='03_PL'!B11"],
    ["経常利益(結論)","='03_PL'!B8"],
    ["◆ ボトルネック＝営業時間（目標/予定/実績）",""],
    ["営業直結比率","=TEXT('05_時間配分'!B2,\"0%\")&\" / \"&TEXT('05_時間配分'!B5,\"0%\")&\" / \"&TEXT('05_時間配分'!B8,\"0%\")"],
    ["計画と実行のギャップ(予定−実績)","=TEXT('05_時間配分'!B9,\"0%\")"],
    ["◆ 今日のNorth Star",""],
    ["今日PL科目に効く行動を取れたか","→ 02_営業ログに『科目つき行動』が1行でも入ったか"],
    ["今日の一手","栄町=大坪さんへ口座確認連絡(6/8決済の生命線)"],
  ]);
  head(s0,"A1:B1");
  ["A2:B2","A6:B6","A11:B11","A14:B14"].forEach(function(a){ s0.getRange(a).setBackground("#EAE0DA").setFontWeight("bold"); });
  bg(s0,"B3:B5",B); bg(s0,"B7:B9",B); bg(s0,"B10",GOLD); s0.getRange("B10").setFontWeight("bold"); bg(s0,"B12:B13",B); bg(s0,"B15:B16",O);

  // ★使い方・動線
  var sx=mk("★使い方・動線");
  put(sx,[
    ["★ 経営操縦席 設計版 — 使い方と動線",""],
    ["North Star","今日、PLのゴール科目(医療コンサル/物件売却/EC粗利)に効く行動を取れたか"],
    ["運用プロトコル","あなたは『報告』するだけ。例:『曾我に追客した/栄町確度上がった/EC精算◯万』"],
    ["","→ Claudeが 02_営業ログ・01_売上見込み に転記 → 03_PL・04_資金繰り・00_司令塔が自動更新"],
    ["","行は手で増やさない。トリガーは不要＝Claudeが転記エンジン"],
    ["3層構造","L1入力(01売上見込み/02営業ログ/05時間配分) → L2自動(03PL/04資金繰り) → L3司令塔"],
    ["色ルール","🟡黄=入力 / 🟧橙=毎日見る / 🟦青=見る(損益/現金) / ⬜灰=自動・触らない / 金=結論(経常利益)"],
    ["注意","これは設計プロトタイプ。作り込み(BS自動化/MF連携)は栄町6/20決済後。今は動線確認用。"],
  ]);
  head(sx,"A1:B1"); bg(sx,"A2:A8",G);

  // 並び順：表示→入力群→自動→使い方（入力タブを並べて分離）
  var order=["00_司令塔","01_売上見込み","02_営業ログ","05_時間配分","03_PL","04_資金繰り","★使い方・動線"];
  order.forEach(function(nm,i){ var s=ss.getSheetByName(nm); if(s){ ss.setActiveSheet(s); ss.moveActiveSheet(i+1); } });
  // タブ色＝入力/表示を一目で（🟡入力 / 🔵表示 / 🟢自動 / 灰説明）
  function tc(nm,c){ var s=ss.getSheetByName(nm); if(s) s.setTabColor(c); }
  tc("00_司令塔","#4A86E8");                                                   // 表示(青)
  ["01_売上見込み","02_営業ログ","05_時間配分"].forEach(function(n){ tc(n,"#F1C232"); }); // 入力(黄)
  ["03_PL","04_資金繰り"].forEach(function(n){ tc(n,"#6AA84F"); });             // 自動(緑)
  tc("★使い方・動線","#999999");
  // デフォルトの空シート削除
  ["シート1","Sheet1"].forEach(function(nm){ var s=ss.getSheetByName(nm); if(s) ss.deleteSheet(s); });
  ss.setActiveSheet(ss.getSheetByName("00_司令塔"));
  return { ok:true, url:ss.getUrl(), tabs:order };
}

// ── v2の3レイヤー(診断/事業計画/KPI→WBS)をコピー版スプシに追加 2026-06-06 ──
// 既存タブ(01_統合司令塔/04_損益PL/03_売上見込み)を参照＝reuse。新規はこの3タブだけ。
function buildV2Layers(body) {
  const ss = SpreadsheetApp.openById((body && body.hostId) || "1Oymt0B8CgUmk8mCgnx0eDFIUWjd6_tt2Repo0WWYBc0");
  const Y="#FFF2CC",B="#CFE2F3",GOLD="#FFE599",G="#ECECEC",BR="#AA2E26",GR="#D9EAD3";
  function mk(name){ var s=ss.getSheetByName(name); if(s) ss.deleteSheet(s); return ss.insertSheet(name); }
  function put(s,a){ s.getRange(1,1,a.length,a[0].length).setValues(a); }
  function head(s,a1){ s.getRange(a1).setBackground(BR).setFontColor("#FFFFFF").setFontWeight("bold"); }
  // 既存タブ名(コピー元と同じ)。無ければ近い名前を探す
  function nm(kw,def){ var a=ss.getSheets(); for(var i=0;i<a.length;i++){ if(a[i].getName().indexOf(kw)>=0) return a[i].getName(); } return def; }
  var SIRE=nm("統合司令塔","01_統合司令塔"), PL=nm("損益","04_損益PL"), URI=nm("売上見込み","03_売上見込み");
  var q=function(s){return "'"+s+"'";};

  // 🔬経営診断（McKinsey 4軸・司令塔/PLを参照）
  var d=mk("🔬経営診断");
  put(d,[
    ["軸","指標","値","判定","So What（だから何をする）"],
    ["収益性","限界利益(粗利・全社)/月","="+q(PL)+"!B23","","医療を毎月化して限界利益を厚く"],
    ["収益性","経常利益(全社)/月","="+q(PL)+"!B25","=IF(C3>=0,\"🟢黒字\",\"🔴赤字\")","毎月の穴を営業で埋める"],
    ["安全性","純資産","="+q(SIRE)+"!B5","🟢本物","流動性は薄い→現金化導線を持つ"],
    ["安全性","現預金(流動性)","="+q(SIRE)+"!B10","="+q(SIRE)+"!C11","栄町190万が当面の生命線"],
    ["安全性","ランウェイ(月)","="+q(SIRE)+"!B11","="+q(SIRE)+"!C11",""],
    ["効率性","🔴営業直結 時間比率","="+q(SIRE)+"!B24","=IF(C7>=0.6,\"🟢\",\"🔴未達\")","★最重要ボトルネック=内務削って営業へ"],
    ["成長性","総資産 / 総負債","="+q(SIRE)+"!B6","="+q(SIRE)+"!B7","法人債務超過-42万を監視"],
    ["","",""," ←詳細は各タブ：限界利益/経常="+PL+"・純資産/現金/比率="+SIRE,""],
  ]);
  head(d,"A1:E1"); d.getRange("C2:C8").setBackground(B);

  // 🎯事業計画（時間ROIで営業コミット配分）
  var p=mk("🎯事業計画");
  put(p,[
    ["ストリーム","期待値/件","確度","想定工数","時間ROI(粗利/h)","コミット","今月の的"],
    ["医療コンサル",1100000,"0.4-0.6","中","高","◎主軸","曾我/内山+福井140医師→毎月0.7件"],
    ["物件売却","190-400万","0.3-0.9","大","中","○","栄町6/20出口→次の仕入"],
    ["EC粗利",142731,"0.7","小(ゆーし)","維持","△ストック","KYC解錠待ち"],
    ["メディア",1100000,"0.05","大","仕込み","種まき","X/note/診療圏ミニ診断"],
    ["","","","","","",""],
    ["結論","医療を毎月化＋栄町出口＝家族ライン突破。営業時間の60%を医療へ寄せる。","","","","",""],
    ["連動","金額の正は"+URI+"タブ（ここは戦略配分の判断用）","","","","",""],
  ]);
  head(p,"A1:G1"); p.getRange("A7:G7").setBackground(GOLD).setFontWeight("bold");

  // 🪜KPI→WBS（経営目標→本部KPI→週次→日次のカスケード）
  var k=mk("🪜KPI→WBS");
  put(k,[
    ["階層","内容","数値/担当"],
    ["① 経営目標(BS)","純資産1億 / 半期500万 / 毎月の穴を埋める","穴=04_損益PLのB34"],
    ["② 本部KPI","04医療=月0.7件","04 福井/李牧"],
    ["","05物件=四半期1本(栄町→次)","05 川股"],
    ["","03EC=粗利14万/月 維持","03 ゆーし"],
    ["","全社=営業直結 時間比率60%","秘書/01"],
    ["③ 週次WBS","医療→福井MTG+追客15人 / 物件→栄町決済+新規仕入 / 時間→営業枠6h死守","毎週月"],
    ["④ 日次タスク","Google Tasks + 日報(実績h) ＝実行の最小単位","毎日"],
    ["連動の肝","上から下まで数値が繋がる＝今日のタスクが経営目標のどこに効くか一目","—"],
    ["報告→自動検出","菊池の報告をClaudeが検出→01売上見込み/02営業ログ/日報へ転記→上位KPIが自動更新","Claude"],
  ]);
  head(k,"A1:C1");
  ["A2:C2","A3:C3","A7:C7","A8:C8"].forEach(function(a){ k.getRange(a).setBackground(GR); });

  // 並び：診断/事業計画/KPI-WBS を司令塔の直後(2番目)へ
  ["🔬経営診断","🎯事業計画","🪜KPI→WBS"].forEach(function(nm2,i){
    var s=ss.getSheetByName(nm2); if(s){ ss.setActiveSheet(s); ss.moveActiveSheet(i+2); }
  });
  var top=ss.getSheetByName(SIRE); if(top) ss.setActiveSheet(top);
  return { ok:true, url:ss.getUrl(), added:["🔬経営診断","🎯事業計画","🪜KPI→WBS"], ref:{司令塔:SIRE,PL:PL,売上見込み:URI} };
}

// ── 改良案(03中心)をコピー版に実装。連動(B/E/F/G/K)は触らず追加のみ 2026-06-06 ──
function buildKairyou(body) {
  const ss = SpreadsheetApp.openById((body && body.hostId) || "1Oymt0B8CgUmk8mCgnx0eDFIUWjd6_tt2Repo0WWYBc0");
  const Y="#FFF2CC",B="#CFE2F3",G="#ECECEC",BR="#AA2E26",GR="#D9EAD3";
  function shk(kw){ var a=ss.getSheets(); for(var i=0;i<a.length;i++){ if(a[i].getName().indexOf(kw)>=0) return a[i]; } return null; }
  // 1) v2タブ(設計途中版)を削除＝03中心に一本化
  ["🔬経営診断","🎯事業計画","🪜KPI→WBS"].forEach(function(nm){ var s=ss.getSheetByName(nm); if(s) ss.deleteSheet(s); });

  // 1b) 📥報告ログ（APPEND専用＝ログ駆動の心臓。Claudeが報告から1行追記）
  var lg=ss.getSheetByName("📥報告ログ"); if(lg) ss.deleteSheet(lg); lg=ss.insertSheet("📥報告ログ");
  lg.getRange(1,1,4,7).setValues([
    ["日付","種別","案件・相手","科目","項目","報告値","メモ"],
    ["2026-06-06","営業","曾我先生","医療","確度","0.4","反応微妙→様子見"],
    ["2026-06-06","物件","栄町","物件","次アクション","大坪へ口座確認","6/8決済"],
    ["★APPEND専用(消さない)。Claudeが報告から1行追記→02/03が最新値を参照→01/04/05が自動更新。過去は残るので連動が崩れない","","","","","",""]
  ]);
  lg.getRange("A1:G1").setBackground(BR).setFontColor("#FFFFFF").setFontWeight("bold");
  lg.getRange("A2:G3").setBackground(Y); lg.getRange("A4").setFontColor(BR).setFontWeight("bold");

  // 2) 03_売上見込み を「全業務ハブ」に拡張（N列以降＝追加・連動列は不可侵）
  var u=shk("売上見込み");
  u.getRange("N4").setValue("業務種別"); u.getRange("O4").setValue("売上化?"); u.getRange("P4").setValue("次アクション"); u.getRange("Q4").setValue("期限");
  var ext=[
    ["物件","🟢直結","大坪へ口座確認→6/8決済","6/8"],
    ["医療","🟢直結","福井に提示催促(反応微妙→様子見)","随時"],
    ["物件","🟡仕込み","宮崎とテレアポ設計",""],
    ["物件","🟡仕込み","新規仕入ソーシング",""],
    ["医療","🟡仕込み","セミナー後追客",""],
    ["医療","🟡仕込み","My AI提案デモ",""],
    ["物件","🟡仕込み","横浜NPO 福井MTG","6/15"],
  ];
  u.getRange(5,14,ext.length,4).setValues(ext);
  u.getRange("N5:Q14").setBackground(Y);
  u.getRange("N4:Q4").setBackground(BR).setFontColor("#FFFFFF").setFontWeight("bold");

  // 2b) 非売上業務も"売上化?"で横断（連動に入らない下部ブロック r34〜）
  u.getRange("A34").setValue("■ 非売上業務も「売上化?」で横断（売上になってるか常に意識）").setFontWeight("bold");
  var ns=[
    ["調査士(朝活)","内務","⬜自己投資","2027合格→コンサル単価UP"],
    ["家族/親子","00","⬜死守","記念日先回り"],
    ["記帳/税務/残高更新","内務","⬜守り","月次・最小化しAIへ"],
    ["メディア発信(X/note)","仕込み","🟡仕込み","プロTTPで集客装置化"],
  ];
  u.getRange(35,1,ns.length,4).setValues(ns);
  u.getRange("A35:D38").setBackground(G);
  u.getRange("C35:C38").setBackground(Y);

  // 2c) KPI＆時間サマリー（07-11を集約＝既存タブ参照）r40〜
  var SIRE=shk("統合司令塔").getName(), PL=shk("損益").getName();
  u.getRange("A40").setValue("■ KPI＆時間サマリー（07-11を集約・参照表示）").setFontWeight("bold");
  var kpi=[
    ["期待値合計(確度加重)","=B21"],
    ["🔴営業直結 時間比率(目標60%)","='"+SIRE+"'!B24"],
    ["毎月の穴(家族ライン−粗利)","='"+PL+"'!B34"],
    ["→ 資金繰り 現預金(体力)","='"+SIRE+"'!B10"],
    ["→ ランウェイ(月)","='"+SIRE+"'!B11"],
  ];
  u.getRange(41,1,kpi.length,2).setValues(kpi);
  u.getRange("A41:A45").setBackground(G); u.getRange("B41:B45").setBackground(B);

  // 2d) 営業ドライバー入力（転換率・稼働日＝03に集約。出力はPL/01）
  u.getRange("A47").setValue("■ 営業ドライバー入力（転換率・稼働日をここに集約）").setFontWeight("bold");
  u.getRange(48,1,3,2).setValues([["追客→アポ 転換率",0.5],["アポ→成約 転換率",0.2],["月の稼働日",20]]);
  u.getRange("B48:B50").setBackground(Y);
  u.getRange("A52").setValue("※次段：PLのB55/B56/B60をここ参照に切替＝入力を03へ完全一本化");

  // 2e) 05資金繰り 主格別 出金集計（サイフォSUMIF・追加のみ）
  var cf=shk("資金繰り");
  if(cf){
    cf.getRange("A43").setValue("■ 主格別 出金集計（SUMIF）").setFontWeight("bold");
    cf.getRange(44,1,5,2).setValues([
      ["法人 出金","=SUMIF(A14:A26,\"*法人*\",B14:B26)"],
      ["個人事業 出金","=SUMIF(A14:A26,\"*個人事業*\",B14:B26)"],
      ["プライベート 出金","=SUMIF(A14:A26,\"*プライベート*\",B14:B26)"],
      ["世帯生活費","=SUMIF(A14:A26,\"*世帯*\",B14:B26)"],
      ["全主格 出金合計","=B27"]
    ]);
    cf.getRange("A44:A48").setBackground(G); cf.getRange("B44:B48").setBackground(B);
    cf.getRange("A50").setValue("※次段：主格別ランウェイ＝各主格の現金(06BS)÷各主格の燃焼。BSセル精査後に追加");
  }

  // 3) 01_司令塔は表示専用＝注記(入力は03へ)
  var sire=shk("統合司令塔");
  sire.getRange("D1").setValue("◀表示専用。入力は『03_売上見込み』の黄色セルへ").setFontColor(BR).setFontWeight("bold");

  // 4) タブ整理：見えるのは 03(作業)→01(確認) だけ。07-11・pass・他は非表示
  ["07_本部マトリクス","08_残高クイック入力","09_MF残高","10_収益パイプライン","11_KPI","pass","02_追客リスト","04_損益PL","06_資産負債BS"].forEach(function(nm){
    var s=shk(nm.replace(/^[0-9]+_/,"")) || ss.getSheetByName(nm); if(s) s.hideSheet();
  });
  // 見えるのは 03(作業)→📥報告ログ→01(確認)→05(資金繰り) の4枚だけ
  [shk("売上見込み"),ss.getSheetByName("📥報告ログ"),shk("統合司令塔"),shk("資金繰り")].forEach(function(s,i){ if(s){ s.showSheet(); ss.setActiveSheet(s); ss.moveActiveSheet(i+1); } });
  ss.setActiveSheet(shk("売上見込み"));
  return { ok:true, url:ss.getUrl(), 残:"IMPORTRANGE(EC)再承認・passは元ファイルにあるのでコピーから非表示済" };
}

// ── 経営操縦席 完成版(設計版v1に全要件を実装) 2026-06-06 ──

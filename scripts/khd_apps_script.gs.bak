  ss.setActiveSheet(ss.getSheetByName("01_司令塔"));
  return { ok:true, url:ss.getUrl(), tabs:["01_司令塔","02_報告ログ","03_売上見込み","04_PL","05_資金繰り","06_BS過去実績","📖使い方"] };

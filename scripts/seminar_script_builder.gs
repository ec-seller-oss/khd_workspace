    if (String(data[i][1]).indexOf('クロージング') >= 0) {
      sh.getRange(i + 1, 1, 1, 3).setBackground('#FFF3E0');
    }
    if (String(data[i][1]).indexOf('SECTION') >= 0) {
      sh.getRange(i + 1, 1, 1, 3).setBackground('#E8EAF6').setFontWeight('bold');
    }
  }
  sh.setFrozenRows(1);
}


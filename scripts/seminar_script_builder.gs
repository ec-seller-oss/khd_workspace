/**
 * 5/26 TTセミナー「医療専門不動産のビジネスモデル」
 * 台本＆スライド修正事項スプレッドシート生成スクリプト
 *
 * 使い方:
 *   1. 新規GASプロジェクト（or 既存）にこのコードを貼る
 *   2. buildSeminarSheet() を実行
 *   3. 権限許可
 *   4. 実行ログに出るURLを開く → 「台本」「スライド修正事項」2タブ完成
 *
 * 前提:
 *   - 参加者: 不動産業者を目指すサロン生（資金あり・不動産は初心者の投資家）
 *   - 時間: 30分 / 要点トークメモ形式
 *   - クロージング: サロンLINEグループから個別連絡で個別相談誘導
 *   - HP/LINE/NOTE新規案内なし
 *   - アピール: AI活用・営業効率化・スモビジサロン運営・不動産後の副業/本業スケール戦略
 */

function buildSeminarSheet() {
  const ss = SpreadsheetApp.create('5-26 TTセミナー 台本＆スライド修正 - 医療専門不動産');

  buildScriptTab_(ss);
  buildFixTab_(ss);

  // デフォルトの空シート削除
  const sheet1 = ss.getSheetByName('シート1') || ss.getSheetByName('Sheet1');
  if (sheet1) ss.deleteSheet(sheet1);

  ss.setActiveSheet(ss.getSheetByName('台本'));
  Logger.log('完成: ' + ss.getUrl());
  try {
    Browser.msgBox('完成', 'スプレッドシートを作成しました。\n\nURL: ' + ss.getUrl(), Browser.Buttons.OK);
  } catch (e) {
    // Browser使えない環境（トリガー実行等）はログのみ
  }
  return ss.getUrl();
}

/** タブ①: 台本（時間・スライド・トーク要点） */

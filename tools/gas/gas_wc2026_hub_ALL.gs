/**
 * ⚽ W杯2026観戦ハブ 統合版（全部入り・これ1つでOK）
 * 使い方: スプシ(15E7FU5Zfq…)→拡張機能>Apps Script→【全選択で消してこれを貼る】→ buildAll を実行
 * 作るタブ: 02 / 02b / 03b / 04 / 05 / 06 / 07 / 08（既存は_oldに退避して作り直す＝消えない）
 * ※ 00_README / 01_勝ち点シミュ / 03_日本代表名鑑 は最初に作ったタブをそのまま使う（このGASは触らない）
 *   03bの選手プルダウンは 03_日本代表名鑑 を参照するので、その タブは残しておくこと。
 */
const RED = '#AA2E26', CREAM = '#F9F6EF', YEL = '#FFF2CC', GRY = '#EFEFEF', ORG = '#FCE5CD', BLU = '#CFE2F3', GRN = '#D9EAD3', PUR = '#D9D2E9';

function buildAll() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  rebuild02(ss);   // 観戦スケジュール（全日程・日本時間・放送）
  build02b(ss);    // 全対戦表（全12グループ72試合＋決勝T）
  build03b(ss);    // 采配シミュ（俺が森保なら）
  rebuild04(ss);   // 追っかけ×マネー（日本全網羅＋海外割安銘柄）
  rebuild05(ss);   // 観戦日報
  rebuild06(ss);   // TIPS・師匠・リンク集
  rebuild07(ss);   // 年間観戦カレンダー
  build08(ss);     // Jリーグ×フロンターレ
  SpreadsheetApp.flush();
}

/* ===== helper ===== */
function freshSheet(ss, name, color) {
  const old = ss.getSheetByName(name);
  if (old) { const bk = ss.getSheetByName(name + '_old'); if (bk) ss.deleteSheet(bk); old.setName(name + '_old'); }
  const sh = ss.insertSheet(name);
  if (color) sh.setTabColor(color);
  return sh;
}
function head(sh, row, n, vals) {
  sh.getRange(row, 1, 1, n).setValues([vals]).setBackground(RED).setFontColor('#FFFFFF')
    .setFontWeight('bold').setWrap(true).setHorizontalAlignment('center').setVerticalAlignment('middle');
}
function put(sh, row, vals, widths) {
  if (vals.length) sh.getRange(row, 1, vals.length, vals[0].length).setValues(vals).setWrap(true).setVerticalAlignment('middle');
  if (widths) widths.forEach((w, i) => sh.setColumnWidth(i + 1, w));
}
function sec(sh, row, text) { sh.getRange(row, 1).setValue(text).setFontWeight('bold').setFontColor(RED).setFontSize(12); }
function title(sh, text, n) { sh.getRange(1, 1).setValue(text).setFontWeight('bold').setFontSize(13).setFontColor(RED); sh.getRange(1, 1, 1, n).merge(); }
function sh_block(sh, row, header, pairs) {
  sec(sh, row, header);
  sh.getRange(row + 1, 1, pairs.length, 2).setValues(pairs.map(p => [p[0], p[1]])).setWrap(true).setVerticalAlignment('middle');
  sh.setColumnWidth(1, 16);
}

